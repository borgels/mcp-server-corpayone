# Corpay One OAuth 2.0 app credentials (read from the server environment only;
# never passed as tool arguments). Create an app at
# https://web.<env>.corpayone.com/developers with scopes:
#   expenses.all webhooks.all offline_access
# Then run `npm run auth:grant` once to capture a refresh token.
CORPAYONE_CLIENT_ID=
CORPAYONE_CLIENT_SECRET=
# Long-lived refresh token from the authorization-code grant (offline_access).
CORPAYONE_REFRESH_TOKEN=
# Secret used to validate inbound webhook signatures (X-Roger-Signature).
CORPAYONE_WEBHOOK_SECRET=
# Team (company) id slug; required on most endpoints. Find via GET /v1/teams.
CORPAYONE_TEAM_ID=

# Environment: "staging" (default) or "production". Selects API + identity hosts.
CORPAYONE_ENV=staging
# Optional explicit overrides (otherwise derived from CORPAYONE_ENV). https only.
CORPAYONE_API_BASE_URL=
CORPAYONE_IDENTITY_BASE_URL=
# Redirect URI registered on the Corpay One app (used by `npm run auth:grant`).
CORPAYONE_REDIRECT_URI=http://localhost:53682/corpayone/callback

# Write policy. Writes are blocked unless explicitly enabled.
CORPAYONE_ENABLE_WRITES=false
CORPAYONE_POLICY_PATH=
CORPAYONE_AUDIT_LOG=

# Optional Streamable HTTP transport hardening.
MCP_HTTP_HOST=127.0.0.1
MCP_MAX_BODY_BYTES=10485760
MCP_ALLOWED_ORIGINS=
MCP_ALLOW_ANY_ORIGIN=false
MCP_HTTP_TOKEN=
