# Corpay One API credentials (read from the server environment only; never
# passed as tool arguments). Obtain an API token in Corpay One under
# Settings > Integrations / API. Auth scheme is confirmed during connector
# bring-up (Bearer token by default).
CORPAYONE_API_TOKEN=
# Optional override of the API base URL (defaults to the documented production
# host). Must be https:// (loopback http:// allowed for local mocks).
CORPAYONE_BASE_URL=

# Write policy. Writes are blocked unless explicitly enabled.
CORPAYONE_ENABLE_WRITES=false
CORPAYONE_POLICY_PATH=
CORPAYONE_AUDIT_LOG=

# Optional Streamable HTTP transport hardening.
MCP_HTTP_HOST=127.0.0.1
MCP_MAX_BODY_BYTES=10485760
MCP_ALLOWED_ORIGINS=
MCP_ALLOW_ANY_ORIGIN=false
MCP_HTTP_TOKEN=
